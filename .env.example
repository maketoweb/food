# Supabase (Vite)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# VAPID Push Notifications (desde tu otro proyecto Cloudflare/GitHub)
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_BASE64
VITE_PUSH_WEBHOOK_URL=https://your-cloudflare.pages.dev/api/push-notify
VITE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_SHARED
PUSH_WEBHOOK_SECRET=YOUR_PUSH_WEBHOOK_SECRET

# App Config
VITE_APP_NAME=FoodApp
VITE_APP_TAGLINE=Tu Restaurante Favorito
VITE_DEFAULT_THEME_COLOR=#FF6B35
VITE_APP_VERSION=2.0.0
